          "id": "col_md",
          "label": "Width",
          "info": "For large screen (768px - 991px)",
          "options": [
            { "value": "12", "label": "1/1" },
            { "value": "6", "label": "1/2" },
            { "value": "4", "label": "1/3" },
            { "value": "3", "label": "1/4" },
            { "value": "2-4", "label": "1/5" }
          ],
