            { "value": "4", "label": "1/3" },
            { "value": "3", "label": "1/4" },
            { "value": "2-4", "label": "1/5" }
          ],
          "default": "3"
        },
        {
          "type": "select",
          "id": "col_xxl",
          "label": "Width",
          "info": "For xxxlarge screen (1400px - infinity)",
          "options": [
            { "value": "12", "label": "1/1" },
            { "value": "6", "label": "1/2" },
            { "value": "4", "label": "1/3" },
            { "value": "3", "label": "1/4" },
            { "value": "2-4", "label": "1/5" }
          ],
          "default": "3"
        }
      ]
    },
    {
      "type": "newsletter_social",
      "name": "Newsletter & Social",
      "settings": [
        { "type": "header", "content": "Newsletter" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "textarea", "id": "subtext", "label": "Subtext" },
        { "type": "header", "content": "Social media icons", "info": "To display your social media accounts, link them in your theme settings." },
