<link rel="stylesheet" href="{{ 'component-accordion.css' | asset_url }}" media="print" onload="this.media='all'">

<section class="footer-system" aria-label="Footer bilgi alanı">
  <div class="container">
    <div class="footer-system__inner">
      {%- assign fallback_keywords = 'canta aksesuari|canta|giyim|tatil|seyahat urunleri|deniz malzemeleri|spor malzemeleri|egzersiz urunleri|Blazepod|boxbollen|bestway|boldy|intex|Spor|Egzersiz' | split: '|' -%}
      {%- assign parsed_keywords = blank -%}
      {%- if section.settings.keywords_heading contains ':' -%}
        {%- assign keywords_csv = section.settings.keywords_heading | split: ':' | last -%}
        {%- assign parsed_keywords = keywords_csv | split: ',' -%}
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="footer-system__main">
          <accordion-component data-accordion-parent="true" class="footer-system__grid">
            {%- for block in section.blocks -%}
              {%- if block.type == 'link_list' -%}
                <div class="footer-system__column" {{ block.shopify_attributes }}>
                  <div class="accordion d-block d-lg-none">
                    <h4 class="accordion__title"><span>{{ block.settings.heading }}</span></h4>
                    <div class="accordion__content footer-system__accordion-content">
                      {%- if block.settings.linklist != blank -%}
                        <ul class="footer-system__links-mobile" role="list">
                          {%- for link in block.settings.linklist.links -%}
                            <li>
                              <a href="{{ link.url }}" class="footer-system__link{% if link.active %} footer-system__link--active{% endif %}">{{ link.title }}</a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}
                    </div>
                  </div>

                  <div class="footer-system__menu d-none d-lg-block">
                    {%- if block.settings.heading != blank -%}
                      <h2 class="footer-system__title">{{ block.settings.heading | escape }}</h2>
                    {%- endif -%}
                    {%- if block.settings.linklist != blank -%}
                      <ul class="footer-system__links" role="list">
                        {%- for link in block.settings.linklist.links -%}
                          <li>
                            <a href="{{ link.url }}" class="footer-system__link{% if link.active %} footer-system__link--active{% endif %}">{{ link.title }}</a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  </div>
                </div>
              {%- else -%}
                <div class="footer-system__column footer-system__column--newsletter" {{ block.shopify_attributes }}>
                  <div class="accordion d-block d-lg-none">
                    <h4 class="accordion__title"><span>{{ block.settings.heading }}</span></h4>
                    <div class="accordion__content footer-system__accordion-content">
                      {%- form 'customer', id: 'FooterNewsletterMobile', class: 'footer-system__newsletter' -%}
                        {%- if block.settings.subtext != blank -%}
                          <p class="footer-system__newsletter-text">{{ block.settings.subtext | escape }}</p>
                        {%- endif -%}
                        <input type="hidden" name="contact[tags]" value="newsletter">
                        <div class="footer-system__newsletter-field">
                          <div class="field">
                            <input
                              id="FooterNewsletterMobile-{{ section.id }}"
                              type="email"
                              name="contact[email]"
                              class="field__input"
                              value="{{ form.email }}"
                              aria-required="true"
                              autocorrect="off"
                              autocapitalize="off"
                              autocomplete="email"
                              placeholder="{{ 'newsletter.label' | t }}"
                              required
                            >
                            <label class="field__label" for="FooterNewsletterMobile-{{ section.id }}">{{ 'newsletter.label' | t }}</label>
                          </div>
                          <button type="submit" class="button button--secondary footer-system__newsletter-button" name="commit">{{ 'newsletter.button_label' | t }}</button>
                        </div>
                        {%- if form.errors -%}
                          <small class="footer-system__newsletter-error">{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</small>
                        {%- elsif form.posted_successfully? -%}
                          <small class="footer-system__newsletter-success">{{ 'newsletter.success' | t }}</small>
                        {%- endif -%}
                      {%- endform -%}

                      {%- if block.settings.show_social -%}
                        <div class="footer-system__social-wrap">
                          {%- if block.settings.social_heading != blank -%}
                            <h3 class="footer-system__social-title">{{ block.settings.social_heading | escape }}</h3>
                          {%- endif -%}
                          {%- render 'social' -%}
                        </div>
                      {%- endif -%}
                    </div>
                  </div>

                  <div class="footer-system__menu d-none d-lg-block">
                    {%- if block.settings.heading != blank -%}
                      <h2 class="footer-system__title">{{ block.settings.heading | escape }}</h2>
                    {%- endif -%}
                    <div class="footer-system__newsletter-desktop">
                      {%- form 'customer', id: 'FooterNewsletterDesktop', class: 'footer-system__newsletter' -%}
                        {%- if block.settings.subtext != blank -%}
                          <p class="footer-system__newsletter-text">{{ block.settings.subtext | escape }}</p>
                        {%- endif -%}
                        <input type="hidden" name="contact[tags]" value="newsletter">
                        <div class="footer-system__newsletter-field">
                          <div class="field">
                            <input
                              id="FooterNewsletterDesktop-{{ section.id }}"
                              type="email"
                              name="contact[email]"
                              class="field__input"
                              value="{{ form.email }}"
                              aria-required="true"
                              autocorrect="off"
                              autocapitalize="off"
                              autocomplete="email"
                              placeholder="{{ 'newsletter.label' | t }}"
                              required
                            >
                            <label class="field__label" for="FooterNewsletterDesktop-{{ section.id }}">{{ 'newsletter.label' | t }}</label>
                          </div>
                          <button type="submit" class="button button--secondary footer-system__newsletter-button" name="commit">{{ 'newsletter.button_label' | t }}</button>
                        </div>
                        {%- if form.errors -%}
                          <small class="footer-system__newsletter-error">{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</small>
                        {%- elsif form.posted_successfully? -%}
                          <small class="footer-system__newsletter-success">{{ 'newsletter.success' | t }}</small>
                        {%- endif -%}
                      {%- endform -%}

                      {%- if block.settings.show_social -%}
                        <div class="footer-system__social-wrap">
                          {%- if block.settings.social_heading != blank -%}
                            <h3 class="footer-system__social-title">{{ block.settings.social_heading | escape }}</h3>
                          {%- endif -%}
                          {%- render 'social' -%}
                        </div>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </accordion-component>
        </div>
      {%- endif -%}

      {%- assign has_meta = false -%}
      {%- if section.settings.menu_enable and section.settings.menu_linklist != blank -%}
        {%- assign has_meta = true -%}
      {%- endif -%}
      {%- if section.settings.keywords_enable -%}
        {%- assign has_meta = true -%}
      {%- endif -%}

      {%- if has_meta -%}
        <div class="footer-system__meta">
          {%- if section.settings.menu_enable and section.settings.menu_linklist != blank -%}
            <nav class="footer-system__policy-nav" aria-label="Alt menü">
              <ul class="footer-system__policy-links" role="list">
                {%- for link in section.settings.menu_linklist.links -%}
                  <li>
                    <a href="{{ link.url }}" class="footer-system__policy-link{% if link.active %} footer-system__policy-link--active{% endif %}"{% if link.current %} aria-current="page"{% endif %}>{{ link.title | escape }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            </nav>
          {%- endif -%}

          {%- if section.settings.keywords_enable -%}
            <div class="footer-system__keywords">
              {%- if section.settings.keywords_linklist != blank -%}
                <ul class="footer-system__keywords-list" role="list">
                  {%- for link in section.settings.keywords_linklist.links -%}
                    <li><a href="{{ link.url }}" class="footer-system__keyword">{{ link.title | escape }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- elsif parsed_keywords != blank -%}
                <ul class="footer-system__keywords-list" role="list">
                  {%- for keyword in parsed_keywords -%}
                    {%- assign keyword_text = keyword | strip -%}
                    {%- if keyword_text != blank -%}
                      <li><a href="{{ routes.search_url }}?q={{ keyword_text | url_encode }}" class="footer-system__keyword">{{ keyword_text }}</a></li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              {%- else -%}
                <ul class="footer-system__keywords-list" role="list">
                  {%- for keyword in fallback_keywords -%}
                    <li><a href="{{ routes.search_url }}?q={{ keyword | url_encode }}" class="footer-system__keyword">{{ keyword }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="footer-system__legal">
        {%- if section.settings.payment_enable -%}
          <div class="footer-system__payment">
            <h3 class="footer-system__payment-title">{{ section.settings.payment_title | default: 'Kabul Edilen Ödeme Yöntemleri' }}</h3>
            {%- if section.settings.payment_image != blank -%}
              <div class="footer-system__payment-image-wrap">
                <img
                  class="footer-system__payment-image"
                  src="{{ section.settings.payment_image | image_url: width: 720 }}"
                  alt="{{ section.settings.payment_title | default: 'Kabul Edilen Ödeme Yöntemleri' | escape }}"
                  loading="lazy"
                  width="720"
                  height="120"
                >
              </div>
            {%- else -%}
              <ul class="footer-system__payment-list" role="list">
                {%- for type in shop.enabled_payment_types -%}
                  <li class="footer-system__payment-item">{{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}</li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="footer-system__copyright">
          {{ 'sections.footer.copyright' | t }} &copy; {{ 'now' | date: "%Y" }} {{ shop.name | link_to: '/' }}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Footer Bottom",
  "settings": [
    { "type": "header", "content": "Menu Footer" },
    { "type": "checkbox", "id": "menu_enable", "label": "Set active this block" },
    { "type": "link_list", "id": "menu_linklist", "label": "Menu", "info": "Displays only top-level menu items." },

    { "type": "header", "content": "Payment methods" },
    { "type": "checkbox", "id": "payment_enable", "label": "Show payment icons" },
    { "type": "text", "id": "payment_title", "label": "Title", "default": "Kabul Edilen Ödeme Yöntemleri" },
    { "type": "image_picker", "id": "payment_image", "label": "Payment methods image" },

    { "type": "header", "content": "Hot Keywords" },
    { "type": "checkbox", "id": "keywords_enable", "label": "Set active this block" },
    { "type": "text", "id": "keywords_heading", "label": "Heading" },
