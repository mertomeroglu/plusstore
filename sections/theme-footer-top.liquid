{% if section.blocks.size > 0 %}
  <div class="top-footer {{ section.settings.display }}">
    <div class="container">
      <div class="top-footer__content row">
        {% for block in section.blocks %}
          {%- assign trust_heading = block.settings.heading | downcase -%}
          {%- assign is_payment_methods_banner = false -%}
          {%- if trust_heading contains 'kabul edilen' and trust_heading contains 'odeme' -%}
            {%- assign is_payment_methods_banner = true -%}
          {%- elsif trust_heading contains 'kabul edilen' and trust_heading contains 'ödeme' -%}
            {%- assign is_payment_methods_banner = true -%}
          {%- elsif trust_heading contains 'payment methods' -%}
            {%- assign is_payment_methods_banner = true -%}
          {%- endif -%}
          {%- if is_payment_methods_banner == false and block.settings.heading != blank -%}
          <div class="top-footer__item col-{{ block.settings.col }} col-sm-{{ block.settings.col_sm }} col-md-{{ block.settings.col_md }} col-lg-{{ block.settings.col_lg }} col-xl-{{ block.settings.col_xl }} col-xxl-{{ block.settings.col_xxl }}">
            {% if trust_heading contains 'kargo' %}
              <div class="top-footer__item-icon top-footer__item-icon--svg" aria-hidden="true">
                <svg class="icon icon-trust" viewBox="0 0 24 24" fill="none" focusable="false" role="presentation">
                  <rect x="2.5" y="8" width="11" height="7" rx="1.4" stroke="currentColor" stroke-width="1.75"/>
                  <path d="M13.5 10.2h4l2 2.4v2.4h-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="6.5" cy="17" r="1.9" stroke="currentColor" stroke-width="1.75"/>
                  <circle cx="17.2" cy="17" r="1.9" stroke="currentColor" stroke-width="1.75"/>
                  <path d="M6 10.8h4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                </svg>
              </div>
            {% elsif trust_heading contains 'odeme' or trust_heading contains 'ödeme' %}
              <div class="top-footer__item-icon top-footer__item-icon--svg" aria-hidden="true">
                <svg class="icon icon-trust" viewBox="0 0 24 24" fill="none" focusable="false" role="presentation">
                  <rect x="2.6" y="6" width="18.8" height="12" rx="2.2" stroke="currentColor" stroke-width="1.75"/>
                  <path d="M2.6 10h18.8" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                  <path d="M6.8 14h4.8" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                  <path d="M14.8 15.3l1.6 1.5 2.8-3" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            {% elsif trust_heading contains 'destek' %}
              <div class="top-footer__item-icon top-footer__item-icon--svg" aria-hidden="true">
                <svg class="icon icon-trust" viewBox="0 0 24 24" fill="none" focusable="false" role="presentation">
                  <path d="M6 10.4V8.8a6 6 0 0 1 12 0v1.6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                  <rect x="3.9" y="10.2" width="3.4" height="6.5" rx="1.3" stroke="currentColor" stroke-width="1.75"/>
                  <rect x="16.7" y="10.2" width="3.4" height="6.5" rx="1.3" stroke="currentColor" stroke-width="1.75"/>
                  <path d="M20.1 16.3a3 3 0 0 1-3 3h-2.3" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                  <rect x="11.4" y="17.4" width="4.2" height="2.6" rx="1.1" stroke="currentColor" stroke-width="1.5"/>
                </svg>
              </div>
            {% elsif trust_heading contains 'iade' %}
              <div class="top-footer__item-icon top-footer__item-icon--svg" aria-hidden="true">
                <svg class="icon icon-trust" viewBox="0 0 24 24" fill="none" focusable="false" role="presentation">
                  <path d="M7.7 7.1A7.5 7.5 0 1 1 5.3 12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                  <path d="M4.2 6.7h4.7v4.7" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M10 12.6l1.6 1.7 3-3.1" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            {% elsif block.settings.icon %}
              <div class="top-footer__item-icon">
                <img class="icon"
                     srcset="{% render 'bgset', image: block.settings.icon %}"
                    	 src="{% render 'srcset', image: block.settings.icon %}"
                     alt="{{ block.settings.icon.alt | escape }}"
                     width="{{ block.settings.icon.width }}"
                     height="{{ block.settings.icon.height }}"
                     >
              </div>
            {% endif %}
            <div class="top-footer__item-content">
              {%- if block.settings.heading != blank -%}
                <p class="top-footer__item-heading">
                  {{ block.settings.heading }}
                </p>
              {%- endif -%}
              {%- if block.settings.subtext != blank -%}
                <p class="top-footer__item-subtext">
                  {{ block.settings.subtext }}
                </p>
              {%- endif -%}
            </div>
          </div>
          {%- endif -%}
        {% endfor %}
      </div>  
    </div>
  </div>
{% endif %}
