{% if section.blocks.size > 0 %}
  <section class="footer-system-top {{ section.settings.display }}" aria-label="Güven ve teslimat">
    <div class="container">
      <div class="footer-system-top__grid">
        {%- assign visible_trust_index = 0 -%}
        {% for block in section.blocks %}
          {%- assign heading_text = block.settings.heading | default: '' | strip -%}
          {%- assign heading_downcase = heading_text | downcase -%}
          {%- assign skip_block = false -%}
          {%- if heading_text == blank -%}
            {%- assign skip_block = true -%}
          {%- endif -%}
          {%- if heading_downcase contains 'kabul edilen' and heading_downcase contains 'odeme' -%}
            {%- assign skip_block = true -%}
          {%- elsif heading_downcase contains 'kabul edilen' and heading_downcase contains 'ödeme' -%}
            {%- assign skip_block = true -%}
          {%- elsif heading_downcase contains 'payment methods' -%}
            {%- assign skip_block = true -%}
          {%- endif -%}

          {% if skip_block == false %}
            {%- assign visible_trust_index = visible_trust_index | plus: 1 -%}
            <article class="footer-system-top__item" {{ block.shopify_attributes }}>
              <div class="footer-system-top__icon" aria-hidden="true">
                {% if visible_trust_index == 1 %}
                  <svg class="footer-system-top__svg" viewBox="0 0 24 24" fill="none" focusable="false" role="presentation">
                    <rect x="2.5" y="8" width="11" height="7" rx="1.4"/>
                    <path d="M13.5 10.2h4l2 2.4v2.4h-6"/>
                    <circle cx="6.5" cy="17" r="1.9"/>
                    <circle cx="17.2" cy="17" r="1.9"/>
                    <path d="M6 10.8h4"/>
                  </svg>
                {% elsif visible_trust_index == 2 %}
                  <svg class="footer-system-top__svg" viewBox="0 0 24 24" fill="none" focusable="false" role="presentation">
                    <rect x="2.6" y="6" width="18.8" height="12" rx="2.2"/>
                    <path d="M2.6 10h18.8"/>
                    <path d="M6.8 14h4.8"/>
                    <path d="M14.8 15.3l1.6 1.5 2.8-3"/>
                  </svg>
                {% elsif visible_trust_index == 3 %}
                  <svg class="footer-system-top__svg" viewBox="0 0 24 24" fill="none" focusable="false" role="presentation">
                    <path d="M6 10.4V8.8a6 6 0 0 1 12 0v1.6"/>
                    <rect x="3.9" y="10.2" width="3.4" height="6.5" rx="1.3"/>
                    <rect x="16.7" y="10.2" width="3.4" height="6.5" rx="1.3"/>
                    <path d="M20.1 16.3a3 3 0 0 1-3 3h-2.3"/>
                    <rect x="11.4" y="17.4" width="4.2" height="2.6" rx="1.1"/>
                  </svg>
                {% elsif visible_trust_index == 4 %}
                  <svg class="footer-system-top__svg" viewBox="0 0 24 24" fill="none" focusable="false" role="presentation">
                    <path d="M7.7 7.1A7.5 7.5 0 1 1 5.3 12"/>
                    <path d="M4.2 6.7h4.7v4.7"/>
                    <path d="M10 12.6l1.6 1.7 3-3.1"/>
                  </svg>
                {% elsif block.settings.icon != blank %}
                  <img
                    class="footer-system-top__img"
                    srcset="{% render 'bgset', image: block.settings.icon %}"
                    src="{% render 'srcset', image: block.settings.icon %}"
                    alt="{{ block.settings.icon.alt | escape }}"
                    width="{{ block.settings.icon.width }}"
                    height="{{ block.settings.icon.height }}"
                    loading="lazy"
                  >
                {% else %}
                  <svg class="footer-system-top__svg" viewBox="0 0 24 24" fill="none" focusable="false" role="presentation">
                    <circle cx="12" cy="12" r="8.2"/>
                    <path d="M12 8.2v4.1"/>
                    <circle cx="12" cy="16.6" r="0.8"/>
                  </svg>
                {% endif %}
              </div>

              <div class="footer-system-top__content">
                <p class="footer-system-top__title">{{ heading_text }}</p>
                {% if block.settings.subtext != blank %}
                  <p class="footer-system-top__text">{{ block.settings.subtext }}</p>
                {% endif %}
              </div>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Footer Delivery",
  "settings": [
    {
      "type": "select",
      "id": "display",
      "label": "Display on",
      "options": [
        {
          "value": "",
          "label": "Desktop & Mobile"
        },
        {
          "value": "d-none d-lg-block",
          "label": "Desktop only"
        },
        {
          "value": "d-block d-lg-none",
          "label": "Mobile only"
        }
      ],
      "default": ""
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Upload Icon"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "subtext",
          "label": "Subtext"
        },
        {
          "type": "header",
          "content": "Responsive width"
        },
        {
          "type": "select",
          "id": "col",
          "label": "Width",
          "info": "For small screen (0px - 575px)",
          "options": [
            { "value": "12", "label": "1/1" },
            { "value": "6", "label": "1/2" },
            { "value": "4", "label": "1/3" },
            { "value": "3", "label": "1/4" },
            { "value": "2-4", "label": "1/5" }
          ],
          "default": "12"
        },
        {
          "type": "select",
          "id": "col_sm",
          "label": "Width",
          "info": "For medium screen (576px - 767px)",
          "options": [
            { "value": "12", "label": "1/1" },
            { "value": "6", "label": "1/2" },
            { "value": "4", "label": "1/3" },
            { "value": "3", "label": "1/4" },
            { "value": "2-4", "label": "1/5" }
          ],
          "default": "6"
        },
        {
          "type": "select",
          "id": "col_md",
          "label": "Width",
          "info": "For large screen (768px - 991px)",
          "options": [
            { "value": "12", "label": "1/1" },
            { "value": "6", "label": "1/2" },
            { "value": "4", "label": "1/3" },
            { "value": "3", "label": "1/4" },
            { "value": "2-4", "label": "1/5" }
          ],
          "default": "3"
        },
        {
          "type": "select",
          "id": "col_lg",
          "label": "Width",
          "info": "For xlarge screen (992px - 1199px)",
          "options": [
            { "value": "12", "label": "1/1" },
            { "value": "6", "label": "1/2" },
            { "value": "4", "label": "1/3" },
            { "value": "3", "label": "1/4" },
            { "value": "2-4", "label": "1/5" }
          ],
          "default": "3"
        },
        {
          "type": "select",
          "id": "col_xl",
          "label": "Width",
          "info": "For xxlarge screen (1200px - 1399px)",
          "options": [
            { "value": "12", "label": "1/1" },
            { "value": "6", "label": "1/2" },
            { "value": "4", "label": "1/3" },
            { "value": "3", "label": "1/4" },
            { "value": "2-4", "label": "1/5" }
          ],
          "default": "3"
        },
        {
          "type": "select",
          "id": "col_xxl",
          "label": "Width",
          "info": "For xxxlarge screen (1400px - infinity)",
          "options": [
            { "value": "12", "label": "1/1" },
            { "value": "6", "label": "1/2" },
            { "value": "4", "label": "1/3" },
            { "value": "3", "label": "1/4" },
            { "value": "2-4", "label": "1/5" }
          ],
          "default": "3"
        }
      ]
    }
  ]
}
{% endschema %}
