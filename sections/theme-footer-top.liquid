{% if section.blocks.size > 0 %}
  <div class="top-footer {{ section.settings.display }}">
    <div class="container">
      <div class="top-footer__content row">
        {% for block in section.blocks %}
          {%- assign trust_heading = block.settings.heading | downcase -%}
          <div class="top-footer__item col-{{ block.settings.col }} col-sm-{{ block.settings.col_sm }} col-md-{{ block.settings.col_md }} col-lg-{{ block.settings.col_lg }} col-xl-{{ block.settings.col_xl }} col-xxl-{{ block.settings.col_xxl }}">
            {% if trust_heading contains 'kargo' %}
              <div class="top-footer__item-icon top-footer__item-icon--svg" aria-hidden="true">
                <svg class="icon icon-trust" viewBox="0 0 24 24" fill="none" focusable="false" role="presentation">
                  <path d="M3 7.5h11.5v8H3z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M14.5 10.5h3l2.5 2.7v2.3h-5.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="7" cy="17.5" r="1.7" stroke="currentColor" stroke-width="1.8"/>
                  <circle cx="17" cy="17.5" r="1.7" stroke="currentColor" stroke-width="1.8"/>
                </svg>
              </div>
            {% elsif trust_heading contains 'odeme' or trust_heading contains 'ödeme' %}
              <div class="top-footer__item-icon top-footer__item-icon--svg" aria-hidden="true">
                <svg class="icon icon-trust" viewBox="0 0 24 24" fill="none" focusable="false" role="presentation">
                  <rect x="2.8" y="5.2" width="18.4" height="13.6" rx="2.4" stroke="currentColor" stroke-width="1.8"/>
                  <path d="M2.8 9.2h18.4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M7.2 14.6h4.2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M16 3.2l1.5 1.6 3.1-3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            {% elsif trust_heading contains 'destek' %}
              <div class="top-footer__item-icon top-footer__item-icon--svg" aria-hidden="true">
                <svg class="icon icon-trust" viewBox="0 0 24 24" fill="none" focusable="false" role="presentation">
                  <path d="M6.2 10.3V8.7a5.8 5.8 0 0 1 11.6 0v1.6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  <rect x="4.2" y="10.1" width="3.4" height="6.4" rx="1.4" stroke="currentColor" stroke-width="1.8"/>
                  <rect x="16.4" y="10.1" width="3.4" height="6.4" rx="1.4" stroke="currentColor" stroke-width="1.8"/>
                  <path d="M19.8 16.2a2.8 2.8 0 0 1-2.8 2.8h-2.2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  <rect x="11.8" y="17.6" width="3.6" height="2.2" rx="1" stroke="currentColor" stroke-width="1.4"/>
                </svg>
              </div>
            {% elsif trust_heading contains 'iade' %}
              <div class="top-footer__item-icon top-footer__item-icon--svg" aria-hidden="true">
                <svg class="icon icon-trust" viewBox="0 0 24 24" fill="none" focusable="false" role="presentation">
                  <path d="M8.6 6.3A7.2 7.2 0 1 1 6.2 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M4.6 6.6h4.8v4.8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M10 12.3l1.5 1.6 2.7-2.8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            {% elsif block.settings.icon %}
              <div class="top-footer__item-icon">
                <img class="icon"
                     srcset="{% render 'bgset', image: block.settings.icon %}"
                    	 src="{% render 'srcset', image: block.settings.icon %}"
                     alt="{{ block.settings.icon.alt | escape }}"
                     width="{{ block.settings.icon.width }}"
                     height="{{ block.settings.icon.height }}"
                     >
              </div>
            {% endif %}
            <div class="top-footer__item-content">
              {%- if block.settings.heading != blank -%}
                <p class="top-footer__item-heading">
                  {{ block.settings.heading }}
                </p>
              {%- endif -%}
              {%- if block.settings.subtext != blank -%}
                <p class="top-footer__item-subtext">
                  {{ block.settings.subtext }}
                </p>
              {%- endif -%}
            </div>
          </div>
        {% endfor %}
      </div>  
    </div>
  </div>
{% endif %}
