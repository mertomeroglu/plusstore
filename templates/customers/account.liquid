{{ 'customer.css' | asset_url | stylesheet_tag }}

<div class="account-layout account-shell account-shell--orders">
  <div class="container">
    <div class="account-shell__inner">
      <header class="account-shell__header">
        <div class="account-shell__heading">
          <h1>{{ 'customer.account.title' | t }}</h1>
          <p class="account-shell__subtitle">Hos geldiniz {{ customer.first_name | default: customer.name }}. Siparislerinizi ve hesap bilgilerinizi buradan yonetebilirsiniz.</p>
        </div>
        {% render 'account-panel-nav', current: 'orders' %}
      </header>

      <div class="account-shell__grid" id="profilim">
        <section class="account-shell__main">
          <div class="account-surface account-content__orders">
            <div class="account-surface__head">
              <h2>{{ 'customer.orders.title' | t }}</h2>
              <span class="account-surface__meta">{{ customer.orders_count }} siparis</span>
            </div>
            <div class="account-orders__content">
              {% paginate customer.orders by 20 %}
                {% if customer.orders.size != 0 %}
                  <table>
                    <thead>
                      <tr>
                        <th class="order_number">{{ 'customer.orders.order_number' | t }}</th>
                        <th class="date">{{ 'customer.orders.date' | t }}</th>
                        <th class="payment_status">{{ 'customer.orders.payment_status' | t }}</th>
                        <th class="fulfillment_status">{{ 'customer.orders.fulfillment_status' | t }}</th>
                        <th class="total">{{ 'customer.orders.total' | t }}</th>
                      </tr>
                    </thead>
                    <tbody>
                      {% for order in customer.orders %}
                      <tr class="{% cycle 'odd', 'even' %} {% if order.cancelled %}cancelled_order{% endif %}">
                        <td class="td-name">{{ order.name | link_to: order.customer_url }}</td>
                        <td class="td-note"><span class="note">{{ order.created_at | date: format: 'short' }}</span></td>
                        <td class="td-authorized"><span class="status_{{ order.financial_status }}">{{ order.financial_status_label }}</span></td>
                        <td class="td-unfulfilled"><span class="status_{{ order.fulfillment_status }}">{{ order.fulfillment_status_label }}</span></td>
                        <td class="td-total"><span class="total money" style="font-family:'currencies'">{{ order.total_price | money }}</span></td>
                      </tr>
                      {% endfor %}
                    </tbody>
                  </table>
                {% else %}
                  <div class="account-empty-state" role="status">
                    <div class="account-empty-state__icon" aria-hidden="true"></div>
                    <h3 class="account-empty-state__title">Henuz siparisiniz bulunmuyor</h3>
                    <p class="account-empty-state__text">Yeni gelen urunleri kesfedin, guvenli alisverise hemen baslayin ve ilk siparisinizi kolayca olusturun.</p>
                    <div class="account-empty-state__actions">
                      <a class="button" href="{{ routes.all_products_collection_url }}">Alisverise Basla</a>
                      <a class="button button--secondary" href="/pages/wish-list">Favorilerime Git</a>
                    </div>
                  </div>
                {% endif %}
                {% include 'pagination' %}
              {% endpaginate %}
            </div>
          </div>
        </section>

        <aside class="account-shell__side">
          <div class="account-surface account-content__details" id="account-details">
            <div class="account-surface__head">
              <h2>{{ 'customer.account.details' | t }}</h2>
            </div>
            <div class="account-details__content">
              <div class="account-details__item">
                <span class="details-item__title">{{'customer.account.name'|t}}:</span>
                <span class="details-item__content">{{ customer.name }}</span>
              </div>
              <div class="account-details__item">
                <span class="details-item__title">{{'customer.account.email'|t}}:</span>
                <a class="details-item__content" href="mailto:{{ customer.email }}">{{ customer.email }}</a>
              </div>
              <div class="account-details__item">
                <span class="details-item__title">{{'customer.account.address'|t}}:</span>
                <address class="details-item__content">{{ customer.default_address.address1 }}, {{ customer.default_address.city}}, {{customer.default_address.country}}</address>
              </div>
              <div class="account-details__item">
                <span class="details-item__title">{{'customer.account.phone'|t}}:</span>
                <a class="details-item__content" href="tel:{{customer.default_address.phone}}">{{customer.default_address.phone}}</a>
              </div>
            </div>
          </div>

          <div class="account-surface account-content__link">
            <div class="account-surface__head">
              <h2>{{'customer.account.title'|t}}</h2>
            </div>
            <div class="account-link__content">
              <ul class="account-link__list">
                <li class="account-link__item">
                  <a href="{{ routes.account_addresses_url }}">{{ 'customer.account.view_addresses' |t }}</a>
                </li>
                <li class="account-link__item">
                  <a href="/pages/wish-list">{{ 'customer.account.view_wishlist' |t }}</a>
                </li>
                <li class="account-link__item">
                  <a href="{{ routes.account_logout_url }}">{{ 'customer.log_out' | t }}</a>
                </li>
              </ul>
            </div>
          </div>

          {%- if settings.account_banner_1 -%}
            <div class="account-content__banner account-surface account-surface--banner">
              <a href="{{ settings.account_banner_1_link }}">
                {%- assign preview_img = settings.account_banner_1 -%}
                <div class="lazy-bg" style="padding-bottom: {{ 100 | divided_by: preview_img.aspect_ratio }}%;">
                  <img {% render 'lazyload', preview_img: preview_img  %} />
                  <span class="data-lazy-loading"></span>
                </div>
              </a>
            </div>
          {%- endif -%}
          {%- if settings.account_banner_2 -%}
            <div class="account-content__banner account-surface account-surface--banner">
              <a href="{{ settings.account_banner_2_link }}">
                {%- assign preview_img = settings.account_banner_2 -%}
                <div class="lazy-bg" style="padding-bottom: {{ 100 | divided_by: preview_img.aspect_ratio }}%;">
                  <img {% render 'lazyload', preview_img: preview_img  %} />
                  <span class="data-lazy-loading"></span>
                </div>
              </a>
            </div>
          {%- endif -%}
        </aside>
      </div>

      <section class="account-dashboard-panels">
        <div class="account-dashboard-grid">
          <div class="account-surface account-dashboard-card" id="bildirimlerim">
            <div class="account-surface__head">
              <h2>Bildirimlerim</h2>
              <a href="{{ routes.account_url }}#bildirimlerim" class="account-dashboard-link">Tumunu Gor</a>
            </div>
            <div class="account-dashboard-card__body">
              {% if customer.orders_count > 0 %}
                <ul class="account-dashboard-list">
                  <li>
                    <strong>Siparis bilgilendirmesi</strong>
                    <span>Son siparislerinizin odeme ve kargo durumunu Siparislerim alanindan takip edebilirsiniz.</span>
                  </li>
                  <li>
                    <strong>Sistem duyurusu</strong>
                    <span>Hesap guvenligi icin sifrenizi duzenli araliklarla guncellemeniz onerilir.</span>
                  </li>
                </ul>
              {% else %}
                <div class="account-mini-empty">
                  <p>Henuz yeni bildiriminiz yok. Siparis veya kampanya guncellemeleri burada listelenecek.</p>
                  <a class="button button--secondary" href="{{ routes.all_products_collection_url }}">Alisverise Basla</a>
                </div>
              {% endif %}
            </div>
          </div>

          <div class="account-surface account-dashboard-card" id="kampanyalar">
            <div class="account-surface__head">
              <h2>Kampanyalar</h2>
            </div>
            <div class="account-dashboard-card__body">
              <ul class="account-dashboard-list">
                <li>
                  <strong>Haftanin firsatlari</strong>
                  <span>Secili urunlerde sepette anlik indirimler sizi bekliyor.</span>
                </li>
                <li>
                  <strong>Ucretsiz kargo avantaji</strong>
                  <span>Belirli sepet tutari uzerindeki siparislerde kargo ucretsiz firsatini kacirmayin.</span>
                </li>
              </ul>
              <div class="account-dashboard-actions">
                <a class="button" href="{{ routes.all_products_collection_url }}">Kampanyali Urunleri Incele</a>
              </div>
            </div>
          </div>

          <div class="account-surface account-dashboard-card" id="kuponlar">
            <div class="account-surface__head">
              <h2>Kuponlar</h2>
            </div>
            <div class="account-dashboard-card__body">
              <div class="account-mini-empty">
                <p>Su anda tanimli aktif kuponunuz bulunmuyor. Yeni kupon kazandiginizda bu alanda otomatik goruntulenir.</p>
                <a class="button button--secondary" href="{{ routes.account_url }}#kampanyalar">Kampanyalara Git</a>
              </div>
            </div>
          </div>

          <div class="account-surface account-dashboard-card" id="ayarlar">
            <div class="account-surface__head">
              <h2>Ayarlar</h2>
            </div>
            <div class="account-dashboard-card__body">
              <ul class="account-dashboard-list">
                <li>
                  <strong>Hesap guvenligi</strong>
                  <span>Sifrenizi yenileyerek hesap guvenliginizi artirabilirsiniz.</span>
                </li>
                <li>
                  <strong>Iletisim tercihleri</strong>
                  <span>Kampanya e-postasi izni: {% if customer.accepts_marketing %}Acik{% else %}Kapali{% endif %}</span>
                </li>
                <li>
                  <strong>Oturum yonetimi</strong>
                  <span>Hesap erisiminizi guvenli sekilde sonlandirmak icin cikis yapabilirsiniz.</span>
                </li>
              </ul>
              <div class="account-dashboard-actions">
                <a class="button button--secondary" href="{{ routes.account_login_url }}#recover">Sifremi Guncelle</a>
                <a class="button" href="{{ routes.account_logout_url }}">Cikis Yap</a>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>
</div>
