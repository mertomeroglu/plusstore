<!-- Premium, modern ve temiz header başlangıcı -->
<header class="premium-header" {% if section.settings.header_sticky %}data-sticky='{"stickTo": "body", "stickyClass": "sticky", "mobileFirst": "true", "responsive": {"992": {"disable": true}}}'{% endif %}>
  <div class="premium-header__container container">
    <div class="premium-header__left">
      {%- if request.page_type == 'index' -%}
      <h1 class="premium-header__heading">
      {%- endif -%}
      <a href="{{ routes.root_url }}" class="premium-header__logo-link">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | img_url: section.settings.logo_width }}" alt="{{ shop.name }}" class="premium-header__logo d-none d-lg-block" width="{{ section.settings.logo.width }}" height="{{ section.settings.logo.height }}">
        {%- elsif section.settings.logo_mobile != blank -%}
          <img src="{{ section.settings.logo_mobile | img_url: section.settings.logo_mobile_width }}" alt="{{ shop.name }}" class="premium-header__logo d-block d-lg-none" width="{{ section.settings.logo_mobile.width }}" height="{{ section.settings.logo_mobile.height }}">
        {%- else -%}
          <span class="premium-header__shopname">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      {%- if request.page_type == 'index' -%}
      </h1>
      {%- endif -%}
    </div>
    <div class="premium-header__center d-none d-lg-flex">
      {%- if section.settings.link_list != blank -%}
        <nav class="premium-header__nav header__inline-menu">
          {%- render 'theme-header-menu', config: section.settings, blocks: section.blocks, menu: linklists[section.settings.link_list] -%}
        </nav>
      {%- endif -%}
    </div>
    <div class="premium-header__right">
      <div class="premium-header__search d-none d-md-block">
        <form action="{{ routes.search_url }}" method="get" role="search" class="premium-header__search-form">
          <input type="hidden" name="type" value="product" />
          <input type="text" name="q" class="premium-header__search-input" placeholder="{{ 'general.search.placeholder' | t }}" />
          <button class="premium-header__search-btn" type="submit" aria-label="icon search">
            <i class="cs-icon icon-search"></i>
          </button>
        </form>
      </div>
      <div class="premium-header__cart">
        <a href="{{ routes.cart_url }}" class="premium-header__cart-link">
          <i class="cs-icon icon-cs-cart"></i>
          <span class="premium-header__cart-text">Sepet</span>
          <span class="premium-header__cart-count">{{ cart.item_count }}</span>
        </a>
      </div>
      {%- if section.settings.contact_enable -%}
      <div class="premium-header__contact d-none d-lg-flex">
        <a href="https://wa.me/905558802818" target="_blank" rel="noopener" class="premium-header__contact-link">
          <span class="premium-header__contact-icon">
            <img src="https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg" width="18" height="18" alt="WhatsApp" loading="lazy">
          </span>
          <span class="premium-header__contact-caption">
            <span>{{ section.settings.contact_title }}</span>
            <span>{{ section.settings.contact_phone }}</span>
          </span>
        </a>
      </div>
      {%- endif -%}
      <div class="premium-header__mobile-menu d-flex d-md-none">
        <a href="{{ routes.search_url }}" class="premium-header__icon-btn" aria-label="Ara">
          <i class="cs-icon icon-search"></i>
        </a>
        {%- if section.settings.link_list != blank -%}
        <header-drawer data-breakpoint="tablet">
          <details class="menu-drawer-container">
            <summary class="premium-header__icon-btn header__icon header__icon--summary link link--text focus-inset" aria-label="{{ 'sections.header.menu' | t }}">
              <i class="cs-icon icon-menu"></i>
              <i class="cs-icon icon-close"></i>
            </summary>
            <div id="premium-menu-drawer" class="menu-drawer motion-reduce" tabindex="-1">
              <div class="menu-drawer__inner-container">
                <div class="menu-drawer__navigation-container component-scrollbar">
                  <nav class="menu-drawer__navigation">
                    <ul class="menu-drawer__menu list-menu" role="list">
                      {%- for link in section.settings.link_list.links -%}
                        <li>
                          {%- if link.links != blank -%}
                            <details>
                              <summary class="menu-drawer__menu-item list-menu__item link link--text focus-inset{% if link.current %} menu-drawer__menu-item--active{% endif %}">
                                {{ link.title | escape }}
                                {% render 'icon-arrow' %}
                                {% render 'icon-caret' %}
                              </summary>
                              <div id="link-{{ link.title | escape }}" class="menu-drawer__submenu motion-reduce" tabindex="-1">
                                <div class="menu-drawer__inner-submenu">
                                  <button class="menu-drawer__close-button link link--text focus-inset" aria-expanded="true">
                                    {% render 'icon-arrow' %}
                                    {{ link.title | escape }}
                                  </button>
                                  <ul class="menu-drawer__menu list-menu" role="list" tabindex="-1">
                                    {%- for childlink in link.links -%}
                                      <li>
                                        {%- if childlink.links == blank -%}
                                          <a href="{{ childlink.url }}" class="menu-drawer__menu-item link link--text list-menu__item focus-inset{% if childlink.current %} menu-drawer__menu-item--active{% endif %}"{% if childlink.current %} aria-current="page"{% endif %}>
                                            {{ childlink.title | escape }}
                                          </a>
                                        {%- else -%}
                                          <details>
                                            <summary class="menu-drawer__menu-item link link--text list-menu__item focus-inset">
                                              {{ childlink.title | escape }}
                                              {% render 'icon-arrow' %}
                                              {% render 'icon-caret' %}
                                            </summary>
                                            <div id="childlink-{{ childlink.title | escape }}" class="menu-drawer__submenu motion-reduce">
                                              <button class="menu-drawer__close-button link link--text focus-inset" aria-expanded="true">
                                                {% render 'icon-arrow' %}
                                                {{ childlink.title | escape }}
                                              </button>
                                              <ul class="menu-drawer__menu list-menu" role="list" tabindex="-1">
                                                {%- for grandchildlink in childlink.links -%}
                                                  <li>
                                                    <a href="{{ grandchildlink.url }}" class="menu-drawer__menu-item link link--text list-menu__item focus-inset{% if grandchildlink.current %} menu-drawer__menu-item--active{% endif %}"{% if grandchildlink.current %} aria-current="page"{% endif %}>
                                                      {{ grandchildlink.title | escape }}
                                                    </a>
                                                  </li>
                                                {%- endfor -%}
                                              </ul>
                                            </div>
                                          </details>
                                        {%- endif -%}
                                      </li>
                                    {%- endfor -%}
                                  </ul>
                                </div>
                              </div>
                            </details>
                          {%- else -%}
                            <a href="{{ link.url }}" class="menu-drawer__menu-item list-menu__item link link--text focus-inset{% if link.current %} menu-drawer__menu-item--active{% endif %}"{% if link.current %} aria-current="page"{% endif %}>
                              {{ link.title | escape }}
                            </a>
                          {%- endif -%}
                        </li>
                      {%- endfor -%}
                    </ul>
                  </nav>
                </div>
              </div>
            </div>
          </details>
        </header-drawer>
        {%- endif -%}
      </div>
    </div>
  </div>
</header>
